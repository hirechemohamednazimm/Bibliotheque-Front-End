<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 600px;">
  <h2 class="mb-4"><i class="bi bi-star text-warning me-2"></i>Ajouter un avis</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/reviews/add" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label">Livre <span class="text-danger">*</span></label>
      <select name="bookId" class="form-select" required>
        <option value="">-- Choisir un livre --</option>
        <% books.forEach(b => { %>
          <option value="<%= b.id %>"><%= b.title %></option>
        <% }) %>
      </select>
    </div>

    <% if (loggedUser && loggedUser.role === 'admin' && users) { %>
      <div class="mb-3">
        <label class="form-label">Utilisateur <span class="text-danger">*</span></label>
        <select name="userId" class="form-select" required>
          <option value="">-- Choisir un utilisateur --</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.fullname %></option>
          <% }) %>
        </select>
      </div>
    <% } else { %>
      <div class="mb-3">
        <label class="form-label">Auteur de l'avis</label>
        <div class="form-control bg-light"><i class="bi bi-person-circle me-1"></i><%= loggedUser ? loggedUser.fullname : '' %></div>
      </div>
    <% } %>

    <div class="mb-3">
      <label class="form-label">Note <span class="text-danger">*</span></label>
      <div class="d-flex gap-3 align-items-center">
        <% for (let i = 1; i <= 5; i++) { %>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="rating" id="rating<%= i %>" value="<%= i %>" required>
            <label class="form-check-label" for="rating<%= i %>">
              <% for (let s = 1; s <= i; s++) { %><i class="bi bi-star-fill text-warning"></i><% } %>
            </label>
          </div>
        <% } %>
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label">Commentaire</label>
      <textarea name="comment" class="form-control" rows="3" minlength="5" placeholder="Partagez votre avis sur ce livre..."></textarea>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-check-circle me-1"></i>Enregistrer</button>
      <a href="/reviews" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
