<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-star me-2 text-warning"></i>Avis <span class="badge bg-secondary"><%= count %></span></h2>
    <a href="/reviews/add" class="btn btn-warning text-dark"><i class="bi bi-plus-circle me-1"></i>Ajouter</a>
  </div>

  <% if (reviews.length === 0) { %>
    <div class="alert alert-info">Aucun avis trouvé.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Livre</th>
            <th>Utilisateur</th>
            <th>Note</th>
            <th>Commentaire</th>
            <% if (loggedUser && loggedUser.role === 'admin') { %>
              <th class="text-end">Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% reviews.forEach(r => { %>
            <tr>
              <td><%= r.id %></td>
              <td><%= r.Book ? r.Book.title : '—' %></td>
              <td><%= r.User ? r.User.fullname : '—' %></td>
              <td>
                <% for (let i = 1; i <= 5; i++) { %>
                  <i class="bi bi-star<%= i <= r.rating ? '-fill' : '' %> text-warning"></i>
                <% } %>
              </td>
              <td><small><%= r.comment ? r.comment.substring(0, 60) : '—' %></small></td>
              <% if (loggedUser && loggedUser.role === 'admin') { %>
                <td class="text-end">
                  <a href="/reviews/edit/<%= r.id %>" class="btn btn-sm btn-warning me-1"><i class="bi bi-pencil"></i></a>
                  <form action="/reviews/delete/<%= r.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cet avis ?')">
                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <nav>
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="/reviews?page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</main>

<%- include('../footer') %>
