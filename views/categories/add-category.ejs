<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 500px;">
  <h2 class="mb-4"><i class="bi bi-tag text-info me-2"></i>Ajouter une catégorie</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/categories/add" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label">Nom <span class="text-danger">*</span></label>
      <input type="text" name="name" class="form-control" required minlength="2" />
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-info text-white"><i class="bi bi-check-circle me-1"></i>Enregistrer</button>
      <a href="/categories" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
