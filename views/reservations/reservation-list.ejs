<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check me-2 text-info"></i>Réservations <span class="badge bg-secondary"><%= count %></span></h2>
    <a href="/reservations/add" class="btn btn-info text-white"><i class="bi bi-plus-circle me-1"></i>Ajouter</a>
  </div>

  <% if (reservations.length === 0) { %>
    <div class="alert alert-info">Aucune réservation trouvée.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Livre</th>
            <th>Utilisateur</th>
            <th>Date réservation</th>
            <th>Expiration</th>
            <th>Statut</th>
            <% if (loggedUser && loggedUser.role === 'admin') { %>
              <th class="text-end">Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(r => { %>
            <tr>
              <td><%= r.id %></td>
              <td><%= r.Book ? r.Book.title : '—' %></td>
              <td><%= r.User ? r.User.fullname : '—' %></td>
              <td><%= r.reservationDate ? new Date(r.reservationDate).toLocaleDateString('fr-CA') : '—' %></td>
              <td><%= r.expiryDate ? new Date(r.expiryDate).toLocaleDateString('fr-CA') : '—' %></td>
              <td>
                <span class="badge <%= r.status === 'confirmed' ? 'bg-success' : r.status === 'cancelled' ? 'bg-danger' : r.status === 'expired' ? 'bg-secondary' : 'bg-warning text-dark' %>">
                  <%= r.status %>
                </span>
              </td>
              <% if (loggedUser && loggedUser.role === 'admin') { %>
                <td class="text-end">
                  <a href="/reservations/edit/<%= r.id %>" class="btn btn-sm btn-warning me-1"><i class="bi bi-pencil"></i></a>
                  <form action="/reservations/delete/<%= r.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cette réservation ?')">
                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <nav>
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="/reservations?page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</main>

<%- include('../footer') %>
