<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 600px;">
  <h2 class="mb-4"><i class="bi bi-pencil text-warning me-2"></i>Modifier la réservation</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/reservations/edit/<%= reservation.id %>?_method=PUT" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label">Livre</label>
      <select name="bookId" class="form-select">
        <% books.forEach(b => { %>
          <option value="<%= b.id %>" <%= reservation.bookId === b.id ? 'selected' : '' %>><%= b.title %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Utilisateur</label>
      <select name="userId" class="form-select">
        <% users.forEach(u => { %>
          <option value="<%= u.id %>" <%= reservation.userId === u.id ? 'selected' : '' %>><%= u.fullname %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Date de réservation</label>
      <input type="date" name="reservationDate" class="form-control" value="<%= reservation.reservationDate ? new Date(reservation.reservationDate).toISOString().split('T')[0] : '' %>" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Date d'expiration</label>
      <input type="date" name="expiryDate" class="form-control" value="<%= reservation.expiryDate ? new Date(reservation.expiryDate).toISOString().split('T')[0] : '' %>" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Statut</label>
      <select name="status" class="form-select">
        <option value="pending" <%= reservation.status === 'pending' ? 'selected' : '' %>>pending</option>
        <option value="confirmed" <%= reservation.status === 'confirmed' ? 'selected' : '' %>>confirmed</option>
        <option value="cancelled" <%= reservation.status === 'cancelled' ? 'selected' : '' %>>cancelled</option>
        <option value="expired" <%= reservation.status === 'expired' ? 'selected' : '' %>>expired</option>
      </select>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-warning"><i class="bi bi-check-circle me-1"></i>Mettre à jour</button>
      <a href="/reservations" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
