<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-arrow-left-right me-2 text-warning"></i>Emprunts <span class="badge bg-secondary"><%= count %></span></h2>
    <a href="/loans/add" class="btn btn-warning text-dark"><i class="bi bi-plus-circle me-1"></i>Ajouter</a>
  </div>

  <% if (loans.length === 0) { %>
    <div class="alert alert-info">Aucun emprunt trouvé.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Livre</th>
            <th>Utilisateur</th>
            <th>Date emprunt</th>
            <th>Date retour</th>
            <th>Statut</th>
            <% if (loggedUser && loggedUser.role === 'admin') { %>
              <th class="text-end">Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% loans.forEach(loan => { %>
            <tr>
              <td><%= loan.id %></td>
              <td><%= loan.Book ? loan.Book.title : '—' %></td>
              <td><%= loan.User ? loan.User.fullname : '—' %></td>
              <td><%= loan.loanDate ? new Date(loan.loanDate).toLocaleDateString('fr-CA') : '—' %></td>
              <td><%= loan.returnDate ? new Date(loan.returnDate).toLocaleDateString('fr-CA') : '—' %></td>
              <td>
                <span class="badge <%= loan.status === 'returned' ? 'bg-success' : 'bg-warning text-dark' %>">
                  <%= loan.status %>
                </span>
              </td>
              <% if (loggedUser && loggedUser.role === 'admin') { %>
                <td class="text-end">
                  <a href="/loans/edit/<%= loan.id %>" class="btn btn-sm btn-warning me-1"><i class="bi bi-pencil"></i></a>
                  <form action="/loans/delete/<%= loan.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cet emprunt ?')">
                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <nav>
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="/loans?page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</main>

<%- include('../footer') %>
