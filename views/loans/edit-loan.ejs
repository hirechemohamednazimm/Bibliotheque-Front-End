<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 600px;">
  <h2 class="mb-4"><i class="bi bi-pencil text-warning me-2"></i>Modifier l'emprunt</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/loans/edit/<%= loan.id %>?_method=PUT" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label">Livre</label>
      <select name="bookId" class="form-select" required>
        <% books.forEach(b => { %>
          <option value="<%= b.id %>" <%= loan.bookId === b.id ? 'selected' : '' %>><%= b.title %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Utilisateur</label>
      <select name="userId" class="form-select" required>
        <% users.forEach(u => { %>
          <option value="<%= u.id %>" <%= loan.userId === u.id ? 'selected' : '' %>><%= u.fullname %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Date d'emprunt</label>
      <input type="date" name="loanDate" class="form-control" value="<%= loan.loanDate ? new Date(loan.loanDate).toISOString().split('T')[0] : '' %>" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Date de retour</label>
      <input type="date" name="returnDate" class="form-control" value="<%= loan.returnDate ? new Date(loan.returnDate).toISOString().split('T')[0] : '' %>" />
    </div>
    <div class="mb-3">
      <label class="form-label">Statut</label>
      <select name="status" class="form-select">
        <option value="borrowed" <%= loan.status === 'borrowed' ? 'selected' : '' %>>borrowed</option>
        <option value="returned" <%= loan.status === 'returned' ? 'selected' : '' %>>returned</option>
      </select>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-check-circle me-1"></i>Mettre à jour</button>
      <a href="/loans" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
