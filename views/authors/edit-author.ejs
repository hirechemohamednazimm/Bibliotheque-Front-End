<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 600px;">
  <h2 class="mb-4"><i class="bi bi-pencil text-warning me-2"></i>Modifier l'auteur</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/authors/edit/<%= author.id %>?_method=PUT" method="POST" enctype="multipart/form-data" novalidate>
    <div class="mb-3">
      <label class="form-label">Nom <span class="text-danger">*</span></label>
      <input type="text" name="name" class="form-control" value="<%= author.name %>" required minlength="2" />
    </div>
    <div class="mb-3">
      <label class="form-label">Biographie</label>
      <textarea name="bio" class="form-control" rows="4"><%= author.bio || '' %></textarea>
    </div>
    <div class="mb-3">
      <label class="form-label">Photo</label>
      <% if (author.image) { %>
        <div class="mb-2">
          <img src="<%= author.image %>" alt="<%= author.name %>" style="height:100px; width:100px; object-fit:cover; border-radius:50%;" />
          <div class="form-text">Photo actuelle — choisir un nouveau fichier pour la remplacer</div>
        </div>
      <% } %>
      <input type="file" name="image" class="form-control" accept="image/jpeg,image/jpg,image/png,image/gif" />
      <div class="form-text">Formats acceptés : jpg, png, gif — max 10 Mo</div>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-warning"><i class="bi bi-check-circle me-1"></i>Mettre à jour</button>
      <a href="/authors" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
