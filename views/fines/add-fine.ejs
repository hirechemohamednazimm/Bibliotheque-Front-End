<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 600px;">
  <h2 class="mb-4"><i class="bi bi-plus-circle text-danger me-2"></i>Ajouter une amende</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/fines/add" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label">Utilisateur <span class="text-danger">*</span></label>
      <select name="userId" class="form-select" required>
        <option value="">-- Choisir un utilisateur --</option>
        <% users.forEach(u => { %>
          <option value="<%= u.id %>"><%= u.fullname %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Emprunt <span class="text-danger">*</span></label>
      <select name="loanId" class="form-select" required>
        <option value="">-- Choisir un emprunt --</option>
        <% loans.forEach(l => { %>
          <option value="<%= l.id %>">Emprunt #<%= l.id %> — <%= l.loanDate ? new Date(l.loanDate).toLocaleDateString('fr-CA') : '' %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Montant ($) <span class="text-danger">*</span></label>
      <input type="number" name="amount" class="form-control" step="0.01" min="0" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Raison <span class="text-danger">*</span></label>
      <input type="text" name="reason" class="form-control" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Statut</label>
      <select name="status" class="form-select">
        <option value="unpaid" selected>unpaid</option>
        <option value="paid">paid</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label">Date de paiement</label>
      <input type="date" name="paidDate" class="form-control" />
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-danger"><i class="bi bi-check-circle me-1"></i>Enregistrer</button>
      <a href="/fines" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
