<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 600px;">
  <h2 class="mb-4"><i class="bi bi-pencil text-warning me-2"></i>Modifier l'utilisateur</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/users/edit/<%= user.id %>?_method=PUT" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label">Nom complet <span class="text-danger">*</span></label>
      <input type="text" name="fullname" class="form-control" value="<%= user.fullname %>" required minlength="3" />
    </div>
    <div class="mb-3">
      <label class="form-label">Email <span class="text-danger">*</span></label>
      <input type="email" name="email" class="form-control" value="<%= user.email %>" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Rôle</label>
      <select name="roleId" class="form-select">
        <option value="">-- Aucun rôle --</option>
        <% roles.forEach(r => { %>
          <option value="<%= r.id %>" <%= user.roleId === r.id ? 'selected' : '' %>><%= r.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-warning"><i class="bi bi-check-circle me-1"></i>Mettre à jour</button>
      <a href="/users" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
