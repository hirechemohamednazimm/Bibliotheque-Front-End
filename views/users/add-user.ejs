<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4" style="max-width: 600px;">
  <h2 class="mb-4"><i class="bi bi-person-plus me-2"></i>Ajouter un utilisateur</h2>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/users/add" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label">Nom complet <span class="text-danger">*</span></label>
      <input type="text" name="fullname" class="form-control" required minlength="3" />
    </div>
    <div class="mb-3">
      <label class="form-label">Email <span class="text-danger">*</span></label>
      <input type="email" name="email" class="form-control" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Mot de passe <span class="text-danger">*</span></label>
      <input type="password" name="password" class="form-control" required minlength="6" />
    </div>
    <div class="mb-3">
      <label class="form-label">Rôle</label>
      <select name="roleId" class="form-select">
        <option value="">-- Aucun rôle --</option>
        <% roles.forEach(r => { %>
          <option value="<%= r.id %>"><%= r.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-secondary"><i class="bi bi-check-circle me-1"></i>Enregistrer</button>
      <a href="/users" class="btn btn-outline-secondary">Annuler</a>
    </div>
  </form>
</main>

<%- include('../footer') %>
