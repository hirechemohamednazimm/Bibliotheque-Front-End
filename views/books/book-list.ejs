<%- include('../head') %>
<%- include('../header') %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journals me-2 text-primary"></i>Livres <span class="badge bg-secondary"><%= count %></span></h2>
    <% if (loggedUser && loggedUser.role === 'admin') { %>
      <a href="/books/add" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Ajouter</a>
    <% } %>
  </div>

  <form class="mb-4" method="GET" action="/books">
    <div class="row g-2">
      <div class="col-md-5">
        <input type="text" name="search" class="form-control" placeholder="Rechercher par titre..." value="<%= search %>" />
      </div>
      <div class="col-md-3">
        <select name="authorId" class="form-select">
          <option value="">Tous les auteurs</option>
          <% authors.forEach(a => { %>
            <option value="<%= a.id %>" <%= authorId == a.id ? 'selected' : '' %>><%= a.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <select name="categoryId" class="form-select">
          <option value="">Toutes les catégories</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>" <%= categoryId == c.id ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2 d-flex gap-2">
        <button class="btn btn-outline-secondary flex-fill" type="submit"><i class="bi bi-search"></i></button>
        <% if (search || authorId || categoryId) { %>
          <a href="/books" class="btn btn-outline-danger"><i class="bi bi-x"></i></a>
        <% } %>
      </div>
    </div>
  </form>

  <% if (books.length === 0) { %>
    <div class="alert alert-info">Aucun livre trouvé.</div>
  <% } else { %>
    <div class="row g-4">
      <% books.forEach(book => { %>
        <%- include('book-card', { book, loggedUser }) %>
      <% }) %>
    </div>

    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="/books?page=<%= i %>&search=<%= search %>&authorId=<%= authorId %>&categoryId=<%= categoryId %>"><%= i %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</main>

<%- include('../footer') %>
