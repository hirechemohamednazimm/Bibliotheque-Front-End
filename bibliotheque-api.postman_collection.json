{
  "info": {
    "name": "Bibliotheque API - Complet",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "authorId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "bookId", "value": "1" },
    { "key": "loanId", "value": "1" },
    { "key": "reservationId", "value": "1" },
    { "key": "reviewId", "value": "1" },
    { "key": "fineId", "value": "1" }
  ],
  "item": [
    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.user && json.user.id) {",
                  "  pm.collectionVariables.set('userId', json.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:5000/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"John Doe\",\n  \"email\": \"john@test.com\",\n  \"password\": \"password123\",\n  \"roleId\": 1\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token sauvegarde automatiquement');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "http://localhost:5000/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2 - Authors",
      "item": [
        {
          "name": "Creer un auteur",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.author && json.author.id) {",
                  "  pm.collectionVariables.set('authorId', json.author.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "http://localhost:5000/api/authors",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Victor Hugo\",\n  \"bio\": \"Ecrivain francais du XIXe siecle\"\n}"
            }
          }
        },
        {
          "name": "Obtenir tous les auteurs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:5000/api/authors?page=1&limit=5"
          }
        },
        {
          "name": "Filtrer auteurs par nom",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "http://localhost:5000/api/authors?name=Victor Hugo"
          }
        }
      ]
    },
