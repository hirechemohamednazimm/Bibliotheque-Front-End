          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "http://localhost:5000/api/fines",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5.00,\n  \"reason\": \"Retard de retour de livre\",\n  \"status\": \"unpaid\",\n  \"loanId\": {{loanId}},\n  \"userId\": {{userId}}\n}"
            }
